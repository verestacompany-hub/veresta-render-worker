{
  "name": "@veresta/video-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render:sample": "NODE_OPTIONS=--require=./scripts/network-shim.cjs remotion render src/index.ts VerestaShort out/sample.mp4 --props=sample-props.json --frames=0-599",
    "worker": "node scripts/worker.mjs",
    "worker:dry": "node scripts/worker.mjs --dry-run",
    "worker:preview": "node scripts/worker.mjs --dry-run --preview-seconds=12",
    "worker:full-preview": "node scripts/worker.mjs --local-full",
    "worker:daemon": "node scripts/daemon.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.490",
    "@types/react": "19.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.490",
    "typescript": "5.9.3"
  }
}
